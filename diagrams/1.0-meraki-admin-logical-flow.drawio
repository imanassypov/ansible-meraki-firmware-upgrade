    <!-- Step 2 -->
    <mxCell id="4" value="&lt;b&gt;Step 2&lt;/b&gt;&lt;br&gt;Discover Firmware Versions&lt;hr size=&quot;1&quot;/&gt;Query available versions&lt;br&gt;for MX &amp;#183; MS &amp;#183; MR"
