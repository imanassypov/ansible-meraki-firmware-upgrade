<mxGraphModel dx="1200" dy="760" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="960" pageHeight="720" math="0" shadow="0">
  <root>
    <mxCell id="0" />
    <mxCell id="1" parent="0" />

    <!-- ═══════════════════════════════════════════════
         NODES
    ═══════════════════════════════════════════════ -->

    <!-- Start -->
    <mxCell id="2" value="&lt;b&gt;Start&lt;/b&gt;&lt;br&gt;Deploy Firmware Upgrade"
      style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;verticalAlign=middle;"
      vertex="1" parent="1">
      <mxGeometry x="10" y="48" width="130" height="64" as="geometry" />
    </mxCell>

    <!-- Step 1 -->
    <mxCell id="3" value="&lt;b&gt;Step 1&lt;/b&gt;&lt;br&gt;Identify Target Networks&lt;hr size=&quot;1&quot;/&gt;Group networks by tag&lt;br&gt;in Meraki Dashboard"
