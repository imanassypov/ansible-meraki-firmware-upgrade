    <!-- Step 7 -->
    <mxCell id="10" value="&lt;b&gt;Step 7&lt;/b&gt;&lt;br&gt;Confirm and Review&lt;hr size=&quot;1&quot;/&gt;Verify scheduling succeeded.&lt;br&gt;Review compliant vs. upgraded."
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;"
      vertex="1" parent="1">
      <mxGeometry x="750" y="185" width="170" height="100" as="geometry" />
    </mxCell>

    <!-- Compliant bypass -->
    <mxCell id="11" value="No action needed.&lt;br&gt;Already on target firmware."
