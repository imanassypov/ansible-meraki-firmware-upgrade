      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;"
      vertex="1" parent="1">
      <mxGeometry x="555" y="20" width="170" height="100" as="geometry" />
    </mxCell>

    <!-- Step 4 -->
    <mxCell id="6" value="&lt;b&gt;Step 4&lt;/b&gt;&lt;br&gt;Define Upgrade Policy&lt;hr size=&quot;1&quot;/&gt;Set schedule, reboot strategy,&lt;br&gt;org and network tag"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;"
      vertex="1" parent="1">
      <mxGeometry x="750" y="20" width="170" height="100" as="geometry" />
    </mxCell>

    <!-- Step 5 -->
    <mxCell id="7" value="&lt;b&gt;Step 5&lt;/b&gt;&lt;br&gt;Check Current State&lt;hr size=&quot;1&quot;/&gt;Query installed firmware&lt;br&gt;per device family"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;"
      vertex="1" parent="1">
      <mxGeometry x="165" y="185" width="170" height="100" as="geometry" />
    </mxCell>

    <!-- Decision -->
    <mxCell id="8" value="Each device family&lt;br&gt;already on&lt;br&gt;target version?"
      style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;verticalAlign=middle;"
      vertex="1" parent="1">
      <mxGeometry x="362" y="188" width="166" height="94" as="geometry" />
    </mxCell>

    <!-- Step 6 -->
    <mxCell id="9" value="&lt;b&gt;Step 6&lt;/b&gt;&lt;br&gt;Schedule the Upgrade&lt;hr size=&quot;1&quot;/&gt;Submit upgrade request:&lt;br&gt;target version &amp;#183; time &amp;#183; strategy"
