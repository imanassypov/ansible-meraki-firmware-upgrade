    </mxCell>

    <mxCell id="11"
      value="&lt;b&gt;Module:&lt;/b&gt;  ansible.builtin.assert  (pre_task)&lt;br&gt;&lt;b&gt;Task:&lt;/b&gt;  Validate network_tags is a non-empty list — fails with clear message if empty&lt;br&gt;&lt;b&gt;Input:&lt;/b&gt;  network_tags variable — sourced from env var MERAKI_NETWORK_TAGS  or  -e flag at runtime"
      style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#aaaaaa;fontSize=10;align=left;verticalAlign=middle;spacingLeft=12;spacingTop=6;spacingBottom=6;"
      vertex="1" parent="1">
      <mxGeometry x="15" y="137" width="750" height="66" as="geometry" />
    </mxCell>

    <!-- arrow: step 1 impl → step 2 header -->
    <mxCell id="a1"
      style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
      edge="1" source="11" target="20" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ═══ STEP 2 ═══ -->
    <mxCell id="20"
      value="&lt;b&gt;Step 2 — Discover Available Firmware Versions&lt;/b&gt;&lt;font style=&quot;font-size:9px;font-weight:normal;&quot;&gt;  (ref. Diagram 1.0 · Step 2)&lt;/font&gt;"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;verticalAlign=middle;align=left;spacingLeft=12;"
      vertex="1" parent="1">
      <mxGeometry x="15" y="223" width="750" height="44" as="geometry" />
    </mxCell>

    <mxCell id="21"
      value="&lt;b&gt;Task 1 · Module:&lt;/b&gt;  cisco.meraki.organizations_info — GET all organizations accessible by the API key&lt;br&gt;&lt;b&gt;Task 2 · Module:&lt;/b&gt;  cisco.meraki.networks_info  (loop per org) — GET all networks; results flattened across all orgs&lt;br&gt;&lt;b&gt;Task 3 · Module:&lt;/b&gt;  ansible.builtin.set_fact  (loop per network) — filter: include network only if its tags list intersects network_tags  (case-sensitive)&lt;br&gt;&lt;b&gt;Task 4 · Module:&lt;/b&gt;  cisco.meraki.networks_firmware_upgrades_info  (loop per tagged network) — GET current + available firmware per network"
      style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#aaaaaa;fontSize=10;align=left;verticalAlign=middle;spacingLeft=12;spacingTop=6;spacingBottom=6;"
      vertex="1" parent="1">
      <mxGeometry x="15" y="267" width="750" height="98" as="geometry" />
    </mxCell>

    <!-- arrow: step 2 impl → step 3 header -->
    <mxCell id="a2"
      style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
      edge="1" source="21" target="30" parent="1">
