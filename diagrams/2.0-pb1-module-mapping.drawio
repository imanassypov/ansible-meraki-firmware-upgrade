    <!-- ═══ TITLE ═══ -->
    <mxCell id="2"
      value="Playbook 1.0 — Check Available Firmware by Tag&lt;br&gt;&lt;font style=&quot;font-size:10px;font-weight:normal;&quot;&gt;How each logical step from Diagram 1.0 maps to an Ansible module&lt;/font&gt;"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1e4d78;strokeColor=none;fontColor=#ffffff;fontSize=13;fontStyle=1;verticalAlign=middle;align=center;"
