      style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#aaaaaa;fontSize=10;align=left;verticalAlign=middle;spacingLeft=12;spacingTop=6;spacingBottom=6;"
