<mxGraphModel dx="900" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="780" pageHeight="1040" math="0" shadow="0">
  <root>
